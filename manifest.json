{
  "manifest_version": 3,
  "name": "New Tab",
  "version": "1.1",
  "description": "Minimal new tab with day tracker, shortcuts pinned.",
  "icons": {
    "16": "icons/icon_gradient_128.png",
    "48": "icons/icon_gradient_128.png",
    "128": "icons/icon_gradient_128.png"
  },
  "permissions": ["storage"],
  "chrome_url_overrides": {
    "newtab": "new-tab/index.html"
  },
  "host_permissions": [],
  "background": {
    "service_worker": "background/background.js"
  }
}
